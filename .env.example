# ── LLM ────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0

# ── Auth MCP ───────────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AUTH_FERNET_KEY=
AUTH_DB_PATH=data/auth.db

# ── Memory MCP backend ──────────────────────────────────────────────────────────
MEMORY_DB_PATH=data/memory.db

# ── Retrieval MCP backend ───────────────────────────────────────────────────────
# Options: tfidf_sqlite (default) | vector (ChromaDB) | postgres (tsvector)
RETRIEVAL_BACKEND=tfidf_sqlite

# tfidf_sqlite backend
RETRIEVAL_DB_PATH=data/retrieval.db

# vector backend (RETRIEVAL_BACKEND=vector) — requires: pip install chromadb
RETRIEVAL_VECTOR_PATH=data/vector_retrieval
RETRIEVAL_VECTOR_COLLECTION=agent_retrieval

# postgres backend (RETRIEVAL_BACKEND=postgres) — requires: pip install psycopg2-binary
RETRIEVAL_POSTGRES_DSN=postgresql://user:password@localhost:5432/agentdb
RETRIEVAL_POSTGRES_LANGUAGE=english

# ── Scheduler MCP backend ───────────────────────────────────────────────────────
# Options: apscheduler (default, in-process) | celery (distributed)
SCHEDULER_BACKEND=apscheduler

# apscheduler backend
SCHEDULER_DB_PATH=data/scheduler.db

# celery backend (SCHEDULER_BACKEND=celery) — requires: pip install celery[redis]
# Celery Beat must be running separately: celery -A <app_module> beat
SCHEDULER_CELERY_BROKER=redis://localhost:6379/0
SCHEDULER_CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── HTTP MCP ───────────────────────────────────────────────────────────────────
HTTP_TIMEOUT_SECONDS=10
HTTP_MAX_RETRIES=3

# ── Notification MCP — Email (SMTP) ────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=you@gmail.com

# ── Notification MCP — Slack ───────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Set to "true" to print notifications to console instead of actually sending
NOTIFICATION_DRY_RUN=true

# ── Logging ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Example: research_agent ────────────────────────────────────────────────────
EMAIL_RECIPIENT=researcher@example.com

# ── Example: monitoring_agent ─────────────────────────────────────────────────
MONITORING_TARGETS=https://httpbin.org/status/200,https://httpbin.org/status/503

# ── Example: flight_monitor ────────────────────────────────────────────────────
# Mode: "mock" (default, zero config) | "amadeus" (real Amadeus API)
FLIGHT_API_MODE=mock

# Amadeus for Developers (required when FLIGHT_API_MODE=amadeus)
# Sign up free at https://developers.amadeus.com → My Apps → Create New App
# Test environment: https://test.api.amadeus.com
# Production:       https://api.amadeus.com
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_BASE_URL=https://test.api.amadeus.com

# Alternatively, store credentials in the auth vault (one-time setup):
#   python -c "
#   from tools.auth_tools import auth_store_key
#   auth_store_key.invoke({'service': 'amadeus', 'key': '<client_id>:<client_secret>'})
#   "
